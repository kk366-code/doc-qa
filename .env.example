# --- LLM プロバイダー選択 ---
# UI のドロップダウンで切り替え可能。起動時のデフォルトに使用 (groq | claude | gemini)
LLM_PROVIDER=groq

# Anthropic Claude（有料）
ANTHROPIC_API_KEY=sk-ant-api03-...

# Groq（無料枠あり: https://console.groq.com）
GROQ_API_KEY=gsk_...

# Google Gemini — AI Studio（無料枠: https://aistudio.google.com/app/apikey）
GEMINI_API_KEY=AIza...

# Google Gemini — Vertex AI（Google Cloud 課金。GOOGLE_CLOUD_PROJECT が設定されていれば優先使用）
# 事前に: gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Database (used when running locally without Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdemo

# --- Optional: Langfuse monitoring ---
# Get these from https://cloud.langfuse.com (free tier available)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
